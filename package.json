{
  "name": "harmonyhill",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "emulators": "firebase emulators:start --import=./emulator-data",
    "all": "turbo run dev & firebase emulators:start --import=./emulator-data",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "luxon": "^3.7.2",
    "react-day-picker": "^9.14.0",
    "react-icons": "^5.6.0",
    "react-photo-album": "^3.5.1",
    "yet-another-react-lightbox": "^3.29.1"
  }
}
