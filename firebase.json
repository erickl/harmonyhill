{
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "source": "apps/web",
        "target": "web",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "frameworksBackend": {
            "region": "asia-southeast1"
        }
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ],
    "emulators": {
        "functions": {
            "port": 5001
        },
        "firestore": {
            "port": 8080,
            "rules": "firestore.rules"
        },
        "auth": {
            "port": 9099
        },
        "storage": {
            "port": 9199,
            "rules": "storage.rules"
        },
        "ui": {
            "enabled": true,
            "port": 4000
        },
        "database": {
            "port": 9000
        },
        "hosting": {
            "port": 5005
        },
        "singleProjectMode": true
    }
}